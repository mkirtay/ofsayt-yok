{
  "name": "ofsayt-yok",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "tweet-bot": "dotenv -e .env.local -- node src/tweet-bot.js",
    "pm2TweetBotStart": "pm2 start \"npm run tweet-bot\" --name tweet-bot --time",
    "pm2TweetBotRestart": "pm2 restart tweet-bot --update-env",
    "pm2TweetBotStop": "pm2 stop tweet-bot",
    "pm2TweetBotDelete": "pm2 delete tweet-bot",
    "pm2TweetBotLogs": "pm2 logs tweet-bot --lines 200",
    "pm2List": "pm2 list",
    "pm2Save": "pm2 save",
    "grant-premium": "dotenv -e .env.local -- node scripts/grant-premium.mjs",
    "video": "dotenv -e .env.local -- npx tsx scripts/video-pipeline/index.ts",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.19.3",
    "@reduxjs/toolkit": "^2.11.2",
    "@sentry/nextjs": "^10.53.1",
    "@stripe/stripe-js": "^9.6.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "date-fns": "^4.1.0",
    "i18next": "^26.2.0",
    "micro": "^10.0.1",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "next-i18next": "^16.0.7",
    "node-cron": "^4.2.1",
    "openai": "^6.35.0",
    "react": "19.2.3",
    "react-datepicker": "^9.1.0",
    "react-dom": "19.2.3",
    "react-i18next": "^17.0.8",
    "react-redux": "^9.2.0",
    "react-virtualized-auto-sizer": "^2.0.3",
    "react-window": "^2.2.7",
    "rss-parser": "^3.13.0",
    "sass": "^1.97.3",
    "stripe": "^22.1.1",
    "twitter-api-v2": "^1.29.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cheerio": "^0.22.35",
    "@types/micro": "^7.3.7",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-datepicker": "^6.2.0",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.7",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^6.19.3",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vercel": "^54.1.0",
    "vitest": "^4.1.7"
  }
}
