generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id            String   @id @default(cuid())
  name          String?
  username      String?  @unique
  bio           String?  @db.Text
  email         String   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          Role     @default(USER)
  /// AI analiz kredisi bakiyesi. Yeni kullanıcı 5 kredi ile başlar.
  credits            Int      @default(5)
  favoriteTeamIds    Int[]
  favoriteLeagueIds  Int[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  accounts      Account[]
  sessions      Session[]
  comments        MatchComment[] @relation("MatchCommentAuthor")
  deletedComments MatchComment[] @relation("MatchCommentDeletedBy")
  userPredictions UserPrediction[]
  creditTransactions CreditTransaction[]
}

/// Kredi hareketleri defteri — bakiye değişikliklerinin denetim izi.
model CreditTransaction {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// "SIGNUP_BONUS" | "PURCHASE" | "ANALYSIS_SPEND" | "ADMIN_GRANT" | "REFUND"
  type         String
  /// Pozitif (ekleme) veya negatif (harcama)
  amount       Int
  balanceAfter Int
  /// ANALYSIS_SPEND için ilgili maç
  matchId      String?
  note         String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([matchId])
}

/// AI üretimli maç analizi cache'i. Aynı maç + status için tek aktif kayıt.
model MatchAnalysis {
  id                 String   @id @default(cuid())
  matchId            String
  /// "PRE" (maç öncesi) | "HT" (devre arası) | "POST" (maç sonu)
  matchStatus        String
  modelVersion       String
  /// Takım kimlikleri ve adları (denormalize — analiz görüntülemede tek sorgu)
  homeTeamId         String?
  awayTeamId         String?
  homeTeamName       String
  awayTeamName       String
  competitionId      String?
  competitionName    String?
  /// Hızlı erişim için takım anlatımları ayrıca tutulur
  homeTeamNarrative  String   @db.Text
  awayTeamNarrative  String   @db.Text
  /// Yapılandırılmış AI çıktıları (Json)
  matchPrediction    Json
  scorePrediction    Json
  goalExpectation    Json
  bettingTips        Json
  teamAnalyses       Json
  /// v2 promptun geniş bölümleri (matchSummary, tacticalAnalysis, heatmapAnalysis,
  /// playerAnalysis, riskFactors, finalVerdict, analystComment)
  fullReport         Json?
  /// "low" | "medium" | "high"
  riskLevel          String
  riskReasoning      String   @db.Text
  /// 0-100 arası modelin kendi güven skoru
  confidenceScore    Float
  /// Maliyet takibi
  tokensUsed         Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now()) @updatedAt
  /// PRE fazında 30 dk TTL; HT/POST için null (kalıcı)
  expiresAt          DateTime?
  predictionRecord   PredictionRecord?

  @@unique([matchId, matchStatus])
  @@index([matchId])
}

/// Tahmin doğruluk takibi — maç bittiğinde MatchAnalysis ile karşılaştırılır.
model PredictionRecord {
  id                  String   @id @default(cuid())
  matchAnalysisId     String   @unique
  matchAnalysis       MatchAnalysis @relation(fields: [matchAnalysisId], references: [id], onDelete: Cascade)
  matchId             String
  matchLabel          String?
  predictedHomePct    Float
  predictedDrawPct    Float
  predictedAwayPct    Float
  predictedScore      String
  predictedOver25     Float
  predictedBtts       Float
  /// "HOME" | "DRAW" | "AWAY"
  actualResult        String?
  actualScore         String?
  actualOver25        Boolean?
  actualBtts          Boolean?
  /// 1X2 isabetli mi (en yüksek olasılığa sahip outcome doğru çıktı mı)
  result1x2Hit        Boolean?
  scoreExactHit       Boolean?
  /// v2 pazarların tahmin değerleri (over35, htOver05, htOver15, homeToScore,
  /// awayToScore, bttsFirstHalf)
  extendedPredictions Json?
  /// Maç bitince hesaplanan isabet/ıska sonuçları (over25Hit, bttsHit, over35Hit,
  /// htOver05Hit, htOver15Hit, homeToScoreHit, awayToScoreHit, bttsFirstHalfHit)
  extendedHits        Json?
  modelVersion        String
  evaluatedAt         DateTime?
  createdAt           DateTime @default(now())

  @@index([matchId])
  @@index([modelVersion, result1x2Hit])
}

/// Kullanıcı maç tahmini — topluluk anketi için (1X2 oyu).
model UserPrediction {
  id         String   @id @default(cuid())
  matchId    String
  userId     String
  /// "HOME" | "DRAW" | "AWAY"
  prediction String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
  @@index([matchId])
}

model MatchComment {
  id                String    @id @default(cuid())
  matchId           String
  body              String    @db.Text
  createdAt         DateTime  @default(now())
  userId            String
  user              User      @relation("MatchCommentAuthor", fields: [userId], references: [id], onDelete: Cascade)
  deletedAt         DateTime?
  deletedByUserId   String?
  deletedBy         User?     @relation("MatchCommentDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  @@index([matchId, createdAt])
}

/// AI üretimli maç trivia/fun-facts cache'i. Aynı maç + status için tek aktif kayıt.
model MatchTrivia {
  id             String    @id @default(cuid())
  matchId        String
  /// "PRE" | "HT" | "POST"
  matchStatus    String
  /// Ertem Şener tarzı absürd ama gerçek istatistikler (string[])
  ertemFacts     Json
  /// Transfer/kariyer bağlam anlatısı
  contextual     String    @db.Text
  /// Tarihi husumeti ve rekabet bağlamı
  rivalryContext String    @db.Text
  modelVersion   String
  tokensUsed     Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt
  /// PRE fazında 2 saat TTL; HT/POST için null (kalıcı)
  expiresAt      DateTime?

  @@unique([matchId, matchStatus])
  @@index([matchId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
