generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id            String   @id @default(cuid())
  name          String?
  username      String?  @unique
  bio           String?  @db.Text
  email         String   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          Role     @default(USER)
  /// Premium üyelik bitiş tarihi; null veya geçmiş tarih → premium değil.
  premiumUntil  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  accounts      Account[]
  sessions      Session[]
  comments      MatchComment[] @relation("MatchCommentAuthor")
  deletedComments MatchComment[] @relation("MatchCommentDeletedBy")
}

/// AI üretimli maç analizi cache'i. Aynı maç + status için tek aktif kayıt.
model MatchAnalysis {
  id                 String   @id @default(cuid())
  matchId            String
  /// "PRE" (maç öncesi) | "HT" (devre arası) | "POST" (maç sonu)
  matchStatus        String
  modelVersion       String
  /// Takım kimlikleri ve adları (denormalize — analiz görüntülemede tek sorgu)
  homeTeamId         String?
  awayTeamId         String?
  homeTeamName       String
  awayTeamName       String
  competitionId      String?
  competitionName    String?
  /// Hızlı erişim için takım anlatımları ayrıca tutulur
  homeTeamNarrative  String   @db.Text
  awayTeamNarrative  String   @db.Text
  /// Yapılandırılmış AI çıktıları (Json)
  matchPrediction    Json
  scorePrediction    Json
  goalExpectation    Json
  bettingTips        Json
  teamAnalyses       Json
  /// "low" | "medium" | "high"
  riskLevel          String
  riskReasoning      String   @db.Text
  /// 0-100 arası modelin kendi güven skoru
  confidenceScore    Float
  /// Maliyet takibi
  tokensUsed         Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now()) @updatedAt
  /// PRE fazında 30 dk TTL; HT/POST için null (kalıcı)
  expiresAt          DateTime?
  predictionRecord   PredictionRecord?

  @@unique([matchId, matchStatus])
  @@index([matchId])
}

/// Tahmin doğruluk takibi — maç bittiğinde MatchAnalysis ile karşılaştırılır.
model PredictionRecord {
  id                  String   @id @default(cuid())
  matchAnalysisId     String   @unique
  matchAnalysis       MatchAnalysis @relation(fields: [matchAnalysisId], references: [id], onDelete: Cascade)
  matchId             String
  predictedHomePct    Float
  predictedDrawPct    Float
  predictedAwayPct    Float
  predictedScore      String
  predictedOver25     Float
  predictedBtts       Float
  /// "HOME" | "DRAW" | "AWAY"
  actualResult        String?
  actualScore         String?
  actualOver25        Boolean?
  actualBtts          Boolean?
  /// 1X2 isabetli mi (en yüksek olasılığa sahip outcome doğru çıktı mı)
  result1x2Hit        Boolean?
  scoreExactHit       Boolean?
  modelVersion        String
  evaluatedAt         DateTime?
  createdAt           DateTime @default(now())

  @@index([matchId])
  @@index([modelVersion, result1x2Hit])
}

model MatchComment {
  id                String    @id @default(cuid())
  matchId           String
  body              String    @db.Text
  createdAt         DateTime  @default(now())
  userId            String
  user              User      @relation("MatchCommentAuthor", fields: [userId], references: [id], onDelete: Cascade)
  deletedAt         DateTime?
  deletedByUserId   String?
  deletedBy         User?     @relation("MatchCommentDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)

  @@index([matchId, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
